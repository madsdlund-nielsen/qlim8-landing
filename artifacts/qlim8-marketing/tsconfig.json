{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts",
    "src/pages/admin.tsx",
    "src/pages/auth.tsx",
    "src/pages/collectors.tsx",
    "src/pages/dashboard.tsx",
    "src/pages/dashboard-archived.tsx",
    "src/pages/klimaagenten.tsx",
    "src/pages/ledger.tsx",
    "src/pages/public-profile.tsx",
    "src/pages/reduction.tsx",
    "src/pages/reporting.tsx",
    "src/pages/onboarding.tsx",
    "src/pages/account.tsx",
    "src/pages/settings.tsx",
    "src/pages/scenario-planner.tsx"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["../../attached_assets/*"]
    }
  }
}

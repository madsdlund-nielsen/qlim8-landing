# Public env vars (bundled into the frontend)
NEXT_PUBLIC_API_URL=https://app.qlim8.com

# Shared secret for the CMS on-publish revalidation webhook (/api/revalidate).
# Must match CMS_REVALIDATE_SECRET in the qlim8-app environment.
CMS_REVALIDATE_SECRET=replace-with-shared-revalidate-secret

# GitHub Actions secrets (sæt disse i Settings → Secrets → Actions)
# HETZNER_HOST=<server-ip>
# HETZNER_USER=root
# HETZNER_SSH_KEY=<privat-nøgle>
